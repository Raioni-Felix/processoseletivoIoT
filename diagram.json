    { "type": "wokwi-photoresistor-sensor", "id": "ldr1", "top": -50, "left": 150, "attrs": {} },
    { "type": "wokwi-pushbutton", "id": "btn1", "top": 50, "left": 150, "attrs": { "color": "green" } }
